@article{carricarte2026layerspecific,
  abbr        = {eLife},
  bibtex_show = {true},
  title       = {Layer-specific spatiotemporal dynamics of feedforward and feedback in human visual object perception},
  author      = {Carricarte, Tony and Xie, Siying and Singer, Johannes and Trampel, Robert and Huber, Laurentius and Lu, Zejin and Kietzmann, Tim C and Weiskopf, Nikolaus and Cichy, Radoslaw M},
  abstract    = {Visual object recognition depends on bidirectional information flow along the ventral visual stream through feedforward and feedback anatomical connections. Using layer-specific fMRI at 7T combined with time-resolved EEG, we isolated feedforward and feedback signals spatially and temporally. Feedforward signals emerge early in the middle layers of early visual cortex and lateral occipital complex, followed by feedback signals in the superficial layer of LOC. Compared against deep neural network models, early feedforward signals encoded medium-to-high complexity features, while later feedback signals conveyed high-complexity features, suggesting feedback actively increases representational complexity in support of object recognition.},
  journal     = {eLife},
  year        = {2026},
  doi         = {10.7554/eLife.111186.1},
  html        = {https://elifesciences.org/reviewed-preprints/111186},
  selected    = {true}
}

@article{carricarte2024laminar,
  abbr        = {iScience},
  bibtex_show = {true},
  title       = {Laminar dissociation of feedforward and feedback in high-level ventral visual cortex during imagery and perception},
  author      = {Carricarte, Tony and Iamshchinina, Polina and Trampel, Robert and Chaimow, Denis and Weiskopf, Nikolaus and Cichy, Radoslaw M},
  abstract    = {Using 7T lamina-resolved fMRI, we found that visual imagery and perception activate high-level ventral visual cortex (fusiform face area and parahippocampal place area) differently at the mesoscale level of cortical layers. Perception shows relatively uniform activation across all three cortical layers, reflecting combined feedforward and feedback processing, while imagery concentrates activation in deep cortical layers, reflecting purely internally generated feedback without external sensory input.},
  journal     = {iScience},
  volume      = {27},
  number      = {7},
  pages       = {110657},
  year        = {2024},
  month       = {July},
  doi         = {10.1016/j.isci.2024.110657},
  html        = {https://www.cell.com/iscience/fulltext/S2589-0042(24)01454-8},
  selected    = {true}
}
